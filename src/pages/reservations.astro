---
import PageHero from '../components/PageHero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Reservations | Zaytouna"
	description="Plan your visit to Zaytouna. For larger groups or preferred times, send a request through OpenTable."
>
	<PageHero
		eyebrow="Visit Planning"
		title="Plan Your Visit To Zaytouna"
		description="Zaytouna is self-service and open Monday to Saturday. Use the request panel below if you want to plan ahead for groups or peak hours."
		theme="reservations"
	/>

	<section class="site-container page-section">
		<div class="surface-panel-strong" data-reveal>
			<SectionTitle
				eyebrow="OpenTable"
				title="Send A Visit Request"
				description="Use the panel below to share your party details and preferred timing."
			/>

			<div class="embed-shell" data-reveal data-reveal-delay="70">
				<!-- Replace this placeholder iframe src with your restaurant's real OpenTable embed URL. -->
				<iframe
					title="OpenTable reservation widget"
					src="https://www.opentable.com/widget/reservation/canvas?rid=123456&type=standard&theme=standard&color=1&dark=false&iframe=true&domain=com&lang=en-US"
					loading="lazy"
					class="h-[620px] w-full border-0"
				></iframe>
			</div>

			<div class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between" data-reveal="soft">
				<p class="reservation-note">
					If the embedded panel does not load on your device, use the direct OpenTable link.
				</p>
				<a
					href="https://www.opentable.com/"
					target="_blank"
					rel="noreferrer"
					class="btn-primary w-full sm:w-auto"
				>
					Open OpenTable
				</a>
			</div>
		</div>
	</section>
</BaseLayout>
