---
import PageHero from '../components/PageHero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Reservations | Zaytouna"
	description="Send a reservation request to Zaytouna. We review each request and confirm by phone or email."
>
	<PageHero
		eyebrow="Reservation Requests"
		title="Request A Visit At Zaytouna"
		description="Zaytouna is self-service and open Monday to Friday, 8:00 AM to 7:00 PM, and Saturday, 8:00 AM to 5:00 PM. Share your preferred date and time, and our team will confirm by phone or email."
		theme="reservations"
	/>

	<section class="site-container page-section">
		<div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
			<div class="surface-panel" data-reveal>
				<SectionTitle
					eyebrow="How It Works"
					title="Simple Manual C0nfirmation"
					description="Reservation requests are reviewed by our staff and confirmed personally."
				/>
				<ul class="detail-list">
					<li>Best for groups or guests planning ahead</li>
					<li>Mon-Fri 8:00 AM-7:00 PM &middot; Sat 8:00 AM-5:00 PM</li>
					<li>Self-service Mediterranean dining</li>
				</ul>
			</div>

			<div class="surface-panel-strong" data-reveal data-reveal-delay="80">
				<SectionTitle
					eyebrow="Request Form"
					title="Reservation Request"
					description="This is a request form, not an instant booking confirmation."
				/>
				<p class="reservation-note mt-4">
					We'll review your request and confirm by phone or email. Phone number is required; email is optional.
				</p>

				<form
					name="reservation-request"
					method="POST"
					netlify
					data-netlify="true"
					data-netlify-honeypot="bot-field"
					netlify-honeypot="bot-field"
					action="/thank-you/"
					class="mt-6 space-y-4"
					accept-charset="UTF-8"
				>
					<input type="hidden" name="form-name" value="reservation-request" />
					<p class="hidden">
						<label>Do not fill this out: <input name="bot-field" /></label>
					</p>

					<div>
						<label for="reservation-full-name" class="form-label">Full Name</label>
						<input
							id="reservation-full-name"
							name="full_name"
							type="text"
							required
							autocomplete="name"
							class="form-control"
						/>
					</div>

					<div class="form-grid-2">
						<div>
							<label for="reservation-phone" class="form-label">Phone Number</label>
							<input
								id="reservation-phone"
								name="phone"
								type="tel"
								required
								autocomplete="tel"
								class="form-control"
							/>
						</div>
						<div>
							<label for="reservation-email" class="form-label">Email (Optional)</label>
							<input
								id="reservation-email"
								name="email"
								type="email"
								autocomplete="email"
								class="form-control"
							/>
						</div>
					</div>

					<div class="form-grid-2">
						<div>
							<label for="reservation-date" class="form-label">Preferred Date</label>
							<input
								id="reservation-date"
								name="preferred_date"
								type="date"
								required
								class="form-control"
							/>
						</div>
						<div>
							<label for="reservation-time" class="form-label">Preferred Time</label>
							<input
								id="reservation-time"
								name="preferred_time"
								type="time"
								required
								class="form-control"
							/>
						</div>
					</div>

					<div>
						<label for="reservation-guest-count" class="form-label">Number of Guests</label>
						<input
							id="reservation-guest-count"
							name="guest_count"
							type="number"
							min="1"
							required
							class="form-control"
						/>
					</div>

					<div>
						<label for="reservation-notes" class="form-label">Special Notes (Optional)</label>
						<textarea
							id="reservation-notes"
							name="notes"
							rows="5"
							placeholder="Tell us anything helpful about your request."
							class="form-control"
						></textarea>
					</div>

					<button type="submit" class="btn-primary w-full sm:w-auto">Send Reservation Request</button>
				</form>
			</div>
		</div>
	</section>
</BaseLayout>
