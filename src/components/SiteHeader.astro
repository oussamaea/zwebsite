---
interface NavItem {
	label: string;
	href: string;
}

interface Props {
	currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navItems: NavItem[] = [
	{ label: 'Home', href: '/' },
	{ label: 'Menu', href: '/menu' },
	{ label: 'Contact', href: '/contact' },
	{ label: 'Reservations', href: '/reservations' },
	{ label: 'Catering', href: '/catering' }
];

function normalizePath(path: string) {
	if (path.length > 1 && path.endsWith('/')) return path.slice(0, -1);
	return path;
}

const normalizedCurrentPath = normalizePath(currentPath);
---

<header class="site-header" data-site-header>
	<div class="site-container py-3 md:py-4">
		<div class="flex items-center justify-between gap-4 md:gap-8">
			<a href="/" aria-label="Zaytouna home" class="site-logo-lockup">
				<img
					src="/images/logo.svg"
					alt=""
					aria-hidden="true"
					class="site-logo-mark-header"
					width="331"
					height="72"
					decoding="async"
				/>
			</a>

			<details class="mobile-nav md:hidden">
				<summary class="mobile-nav-toggle">
					<span class="sr-only">Toggle navigation menu</span>
					<span class="mobile-nav-toggle-label">Menu</span>
					<span class="mobile-nav-toggle-icon" aria-hidden="true">
						<span></span>
						<span></span>
						<span></span>
					</span>
				</summary>
				<nav aria-label="Mobile primary" class="mobile-nav-panel">
					<ul class="mobile-nav-list">
						{
							navItems.map((item) => {
								const isActive = normalizePath(item.href) === normalizedCurrentPath;
								return (
									<li>
										<a
											href={item.href}
											aria-current={isActive ? 'page' : undefined}
											class:list={['mobile-nav-link', isActive && 'mobile-nav-link-active']}
										>
											{item.label}
										</a>
									</li>
								);
							})
						}
					</ul>
				</nav>
			</details>

			<nav aria-label="Primary" class="hidden md:block">
				<ul class="flex flex-nowrap items-center gap-2">
					{
						navItems.map((item) => {
							const isActive = normalizePath(item.href) === normalizedCurrentPath;
							return (
								<li>
									<a
										href={item.href}
										aria-current={isActive ? 'page' : undefined}
										class:list={['nav-link', isActive && 'nav-link-active']}
									>
										{item.label}
									</a>
								</li>
							);
						})
					}
				</ul>
			</nav>
		</div>
	</div>
</header>
